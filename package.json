{
  "name": "7a0-game",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:web": "npm run dev --workspace=@7a0/web",
    "dev:api": "npm run dev --workspace=@7a0/api",
    "db:generate": "npm run db:generate --workspace=@7a0/api",
    "db:push": "npm run db:push --workspace=@7a0/api",
    "db:seed": "npm run db:seed --workspace=@7a0/api",
    "db:setup": "npm run db:setup --workspace=@7a0/api"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2"
}

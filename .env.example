# ─── Supabase (PostgreSQL) ───────────────────────────────────────────
# 1. Crie um projeto em https://supabase.com
# 2. Vá em Project Settings → Database → Connection string
# 3. Copie a URI "Transaction pooler" (porta 6543) para DATABASE_URL
# 4. Copie a URI "Session mode" ou "Direct" (porta 5432) para DIRECT_URL

# Pooler — usado pela API em runtime (Supabase + Prisma)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexão directa — usada por prisma db push / migrations
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Auth (fase futura)
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# ─── Upstash Redis (opcional, fase futura) ───────────────────────────
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ─── App ─────────────────────────────────────────────────────────────
VITE_API_URL="http://localhost:3001"
NODE_ENV="development"
PORT=3001
